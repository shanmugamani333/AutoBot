# ─── Telegram ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/webhook

# ─── Database ───────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=storebot
POSTGRES_USER=storebot
POSTGRES_PASSWORD=changeme_in_production

# ─── Redis ──────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Ollama (LLM runtime) ───────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_LLM_MODEL=mistral
OLLAMA_VISION_MODEL=llava
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── App settings ───────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=changeme_random_32_chars
LOG_LEVEL=INFO

# ─── Guardrail thresholds ───────────────────────────────
SCOPE_FILTER_MIN_SCORE=0.30
CONFIDENCE_MIN_SCORE=0.70

# ─── Session ────────────────────────────────────────────
SESSION_TTL_SECONDS=1800
SESSION_MAX_TURNS=5

# ─── Rate limits ────────────────────────────────────────
RATE_LIMIT_MESSAGES_PER_MIN=10
RATE_LIMIT_MAX_OPEN_DISPUTES=3

# ─── Points ─────────────────────────────────────────────
LOYALTY_POINTS_RATE=0.05
POINTS_CACHE_TTL_SECONDS=600

# ─── Admin ──────────────────────────────────────────────
ADMIN_TELEGRAM_CHAT_ID=
